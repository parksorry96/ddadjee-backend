# ===== 데이터베이스 설정 =====
  DB_HOST=localhost
  DB_PORT=5432
  DB_NAME=ddadjee
  DB_USERNAME=ddadjee
  DB_PASSWORD=ddadjee123

  # ===== Redis 설정 =====
  REDIS_HOST=localhost
  REDIS_PORT=6380
  REDIS_PASSWORD=

  # ===== JWT 설정 (RSA 키 경로) =====
  JWT_PRIVATE_KEY_PATH=classpath:keys/private_key.pem
  JWT_PUBLIC_KEY_PATH=classpath:keys/public_key.pem
  JWT_ISSUER=ddadjee-platform

  # ===== OAuth2 소셜 로그인 =====
  # Google OAuth2
  GOOGLE_CLIENT_ID=your-google-client-id-here
  GOOGLE_CLIENT_SECRET=your-google-client-secret-here

  # Kakao OAuth2
  KAKAO_CLIENT_ID=your-kakao-client-id-here
  KAKAO_CLIENT_SECRET=your-kakao-client-secret-here

  # Naver OAuth2
  NAVER_CLIENT_ID=your-naver-client-id-here
  NAVER_CLIENT_SECRET=your-naver-client-secret-here

  # ===== 공공 API 키 =====
  # 공공데이터포털 (data.go.kr)
  DATA_GO_KR_SERVICE_KEY=your-data-go-kr-api-key

  # 한국산업인력공단 Q-Net
  QNET_API_KEY=your-qnet-api-key

  # ===== 이메일 서비스 (SMTP) =====
  MAIL_HOST=smtp.gmail.com
  MAIL_PORT=587
  MAIL_USERNAME=your-email@gmail.com
  MAIL_PASSWORD=your-app-specific-password
  MAIL_FROM=noreply@ddadjee.com

  # ===== AWS (선택사항) =====
  AWS_ACCESS_KEY_ID=your-aws-access-key
  AWS_SECRET_ACCESS_KEY=your-aws-secret-key
  AWS_REGION=ap-northeast-2
  S3_BUCKET_NAME=ddadjee-storage

  # ===== 서버 설정 =====
  SERVER_PORT=9090
  FRONTEND_URL=http://localhost:5173

  # ===== 로깅 레벨 =====
  LOG_LEVEL=DEBUG